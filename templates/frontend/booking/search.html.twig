{% extends 'frontend/layout/base.html.twig' %}

{% block title %}Recherche de disponibilités{% endblock %}

{% block content %}
<div class="container">
    <h1>Rechercher une disponibilité</h1>
    <p>Sélectionnez vos dates, le nombre de personnes et le type de séjour.</p>

    {# Composant React : formulaire de recherche interactif #}
    <div id="booking-search"
         data-component="BookingSearch"
         data-results-url="{{ path('frontend_booking_results') }}">
    </div>

    {# Fallback HTML si JS désactivé #}
    <noscript>
        <form action="{{ path('frontend_booking_results') }}" method="get" class="search-form">
            <div class="form-row">
                <div class="form-group">
                    <label for="check_in">Arrivée</label>
                    <input type="date" id="check_in" name="check_in" class="form-control" required>
                </div>
                <div class="form-group">
                    <label for="check_out">Départ</label>
                    <input type="date" id="check_out" name="check_out" class="form-control" required>
                </div>
                <div class="form-group">
                    <label for="adults">Adultes</label>
                    <input type="number" id="adults" name="adults" value="2" min="1" max="10" class="form-control">
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Rechercher</button>
        </form>
    </noscript>
</div>
{% endblock %}
