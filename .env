# En local Docker, ne pas committer les secrets réels
# Copier ce fichier en .env.local et y mettre vos vraies valeurs

APP_ENV=dev
APP_SECRET=change_me_in_production_secret_key_here

# URL de connexion à MySQL (Docker)
# Format: mysql://user:password@host:port/database?serverVersion=8.0&charset=utf8mb4
DATABASE_URL="mysql://resa_user:resa_password@db:3306/resa_hotel?serverVersion=8.0.32&charset=utf8mb4"

# MailHog (email de test en local)
MAILER_DSN=smtp://mailhog:1025

# Messenger
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
